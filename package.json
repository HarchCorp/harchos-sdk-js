{
  "name": "@harchos/sdk",
  "version": "0.2.1",
  "description": "The official TypeScript/JavaScript SDK for HarchOS — Carbon-Aware GPU Orchestration Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "harchos",
    "gpu",
    "carbon-aware",
    "sovereign-ai",
    "orchestration",
    "cloud",
    "morocco",
    "africa",
    "green-computing",
    "sustainability",
    "ai-infrastructure"
  ],
  "author": "HarchCorp <contact@harchos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarchCorp/harchos-sdk-js.git"
  },
  "homepage": "https://harchcorp.vercel.app",
  "bugs": {
    "url": "https://github.com/HarchCorp/harchos-sdk-js/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
