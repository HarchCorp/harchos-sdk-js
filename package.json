{
  "name": "@harchos/sdk",
  "version": "0.3.0",
  "description": "The official TypeScript/JavaScript SDK for HarchOS — Carbon-Aware GPU Orchestration Platform with OpenAI-compatible inference",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "harchos",
    "gpu",
    "carbon-aware",
    "sovereign-ai",
    "orchestration",
    "cloud",
    "morocco",
    "africa",
    "green-computing",
    "sustainability",
    "ai-infrastructure",
    "openai-compatible",
    "inference",
    "llm"
  ],
  "author": "HarchCorp <contact@harchos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarchCorp/harchos-sdk-js.git"
  },
  "homepage": "https://harchos.ai",
  "bugs": {
    "url": "https://github.com/HarchCorp/harchos-sdk-js/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
